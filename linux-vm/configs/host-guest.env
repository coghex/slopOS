HOST_ARCH=arm64
HOST_CPU="Apple M3 Max"
GUEST_ARCH=aarch64
QEMU_SYSTEM=qemu-system-aarch64
QEMU_MACHINE=virt
QEMU_ACCEL=hvf
QEMU_MEMORY_MB=4096
LINUX_CONSOLE=ttyAMA0
ROOT_DISK_FILENAME=slopos-root.img
ROOT_DISK_FORMAT=raw
ROOT_DISK_LABEL=slopos-root
ROOT_DISK_DEVICE=vda
PERSISTENT_DISK_FILENAME=slopos-data.img
PERSISTENT_DISK_FORMAT=raw
PERSISTENT_DISK_LABEL=slopos-data
PERSISTENT_DISK_SIZE=24G
PERSISTENT_DISK_DEVICE=vdb
PERSISTENT_MOUNTPOINT=/Volumes/slopos-data
GUEST_SSH_FORWARD_PORT=2222
