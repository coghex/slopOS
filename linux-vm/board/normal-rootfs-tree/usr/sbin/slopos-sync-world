#!/bin/sh
set -eu

STATE_ROOT="${STATE_ROOT:-/Volumes/slopos-data/pkg}"
GUEST_SLOPPKG_BIN="${GUEST_SLOPPKG_BIN:-/usr/local/bin/sloppkg}"
SLOPOS_PUBLISH_HTTP_REPO="${SLOPOS_PUBLISH_HTTP_REPO:-/usr/sbin/slopos-publish-http-repo}"
WORLD_TARGET="${WORLD_TARGET:-}"
CANONICAL_WORLD_TARGET="${CANONICAL_WORLD_TARGET:-selfhost-world}"
GUEST_RECIPE_ROOT="${GUEST_RECIPE_ROOT:-}"
PUBLISH_ONLY=0
SKIP_PUBLISH=0
SKIP_PUBLISH_MAINTENANCE=0

usage() {
  cat >&2 <<'EOF'
Usage: slopos-sync-world [--install-target <package>] [--publish-only] [--skip-publish] [--recipe-root <path>] [--skip-publish-maintenance]

  --install-target <package>  Install a named target instead of upgrading the current world set.
  --publish-only              Refresh the guest unified repo and snapshot, but do not run install/upgrade.
  --skip-publish              Reuse an already refreshed guest repo instead of publishing again.
  --recipe-root <path>        Load packages directly from a recipe tree for convergence/testing.
  --skip-publish-maintenance  Skip remembered repo republish after successful root transactions.

When no world packages are recorded yet, the default upgrade path bootstraps
the canonical target from CANONICAL_WORLD_TARGET (default: selfhost-world).
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --install-target)
      if [ $# -lt 2 ]; then
        usage
        exit 1
      fi
      WORLD_TARGET="$2"
      shift 2
      ;;
    --publish-only)
      PUBLISH_ONLY=1
      shift
      ;;
    --skip-publish)
      SKIP_PUBLISH=1
      shift
      ;;
    --recipe-root)
      if [ $# -lt 2 ]; then
        usage
        exit 1
      fi
      GUEST_RECIPE_ROOT="$2"
      shift 2
      ;;
    --skip-publish-maintenance)
      SKIP_PUBLISH_MAINTENANCE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if [ ! -x "$SLOPOS_PUBLISH_HTTP_REPO" ]; then
  echo "Missing publish helper: $SLOPOS_PUBLISH_HTTP_REPO" >&2
  exit 1
fi

if [ ! -x "$GUEST_SLOPPKG_BIN" ]; then
  echo "Missing guest sloppkg binary: $GUEST_SLOPPKG_BIN" >&2
  exit 1
fi

if [ "$SKIP_PUBLISH" != "1" ]; then
  "$SLOPOS_PUBLISH_HTTP_REPO"
fi

if [ "$PUBLISH_ONLY" = "1" ]; then
  exit 0
fi

set -- "$GUEST_SLOPPKG_BIN" --state-root "$STATE_ROOT"
if [ -n "$GUEST_RECIPE_ROOT" ]; then
  set -- "$@" --recipe-root "$GUEST_RECIPE_ROOT"
fi

install_or_upgrade_args=""
if [ "$SKIP_PUBLISH_MAINTENANCE" = "1" ]; then
  install_or_upgrade_args="--skip-publish-maintenance"
fi

if [ -n "$WORLD_TARGET" ]; then
  exec "$@" install "$WORLD_TARGET" --root / $install_or_upgrade_args
fi

upgrade_log="/tmp/slopos-sync-world.$$.log"
if "$@" upgrade --root / $install_or_upgrade_args >"$upgrade_log" 2>&1; then
  cat "$upgrade_log"
  rm -f "$upgrade_log"
  exit 0
fi

upgrade_status=$?
if grep -Fq "no world packages are recorded" "$upgrade_log"; then
  rm -f "$upgrade_log"
  echo "No recorded world state; bootstrapping canonical target: $CANONICAL_WORLD_TARGET" >&2
  exec "$@" install "$CANONICAL_WORLD_TARGET" --root / $install_or_upgrade_args
fi

cat "$upgrade_log" >&2
rm -f "$upgrade_log"
exit "$upgrade_status"
